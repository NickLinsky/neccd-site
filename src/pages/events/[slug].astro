---
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const modules = import.meta.glob('../../content/events/*.md', { eager: true });
  return Object.entries(modules).map(([path, mod]) => ({
    params: { slug: path.split('/').pop().replace('.md','') },
    props:  { frontmatter: mod.frontmatter, Content: mod.default },
  }));
}

const { frontmatter, Content } = Astro.props;
const tagClass = { Ride: 'tag-ride', Community: 'tag-community', Advocacy: 'tag-advocacy', Resources: 'tag-resources' };

function fmtFull(d) {
  return new Date(d+'T12:00:00').toLocaleDateString('en-US',{weekday:'long',month:'long',day:'numeric',year:'numeric'});
}
---

<Base title={frontmatter.title} description={frontmatter.shortDescription}>

  <div class="container">
    <nav class="breadcrumb">
      <a href="/">Home</a><span>›</span>
      <a href="/events">Events</a><span>›</span>
      <span>{frontmatter.title}</span>
    </nav>
  </div>

  <article class="section">
    <div class="container article-layout">
      <div class="article-body">
        <span class:list={['tag', tagClass[frontmatter.tag] || 'tag-ride']} style="margin-bottom:1rem;display:inline-block;">{frontmatter.tag}</span>
        <h1 class="article-title">{frontmatter.title}</h1>
        <p class="article-summary">{frontmatter.shortDescription}</p>
        <div class="article-content">
          <Content />
        </div>
      </div>

      <aside class="event-meta-card card">
        <div class="meta-row">
          <div class="meta-icon">📅</div>
          <div><div class="meta-label">Date</div><div class="meta-value">{fmtFull(frontmatter.date)}</div></div>
        </div>
        <div class="meta-row">
          <div class="meta-icon">🕐</div>
          <div><div class="meta-label">Time</div><div class="meta-value">{frontmatter.time}</div></div>
        </div>
        <div class="meta-row">
          <div class="meta-icon">📍</div>
          <div><div class="meta-label">Location</div><div class="meta-value">{frontmatter.location}</div></div>
        </div>
        {frontmatter.cost && (
          <div class="meta-row">
            <div class="meta-icon">💰</div>
            <div><div class="meta-label">Cost</div><div class="meta-value">{frontmatter.cost}</div></div>
          </div>
        )}
        {frontmatter.contact && (
          <div class="meta-row">
            <div class="meta-icon">✉️</div>
            <div><div class="meta-label">Contact</div><div class="meta-value">{frontmatter.contact}</div></div>
          </div>
        )}
        <a href="https://band.us/@neccd" class="btn btn-primary" style="width:100%;text-align:center;margin-top:0.5rem;" target="_blank" rel="noopener">Join the conversation on Band</a>
        <a href="/events" class="btn btn-ghost" style="width:100%;text-align:center;margin-top:0.5rem;">← Back to all events</a>
      </aside>
    </div>
  </article>

</Base>

<style>
.breadcrumb { display: flex; align-items: center; gap: 0.5rem; font-size: 0.8rem; color: var(--muted); padding-top: 1.5rem; }
.breadcrumb a { color: var(--muted); }
.breadcrumb a:hover { color: var(--green); }
.breadcrumb span:last-child { color: var(--text); }
.article-layout { display: grid; grid-template-columns: 1fr 300px; gap: 3rem; align-items: start; }
@media (max-width: 720px) { .article-layout { grid-template-columns: 1fr; } .event-meta-card { order: -1; } }
.article-title { font-family: 'Fraunces', serif; font-size: clamp(1.75rem, 3vw, 2.25rem); font-weight: 600; line-height: 1.25; margin-bottom: 0.75rem; }
.article-summary { font-size: 1.05rem; color: var(--muted); line-height: 1.65; margin-bottom: 2rem; padding-bottom: 2rem; border-bottom: 0.5px solid var(--border); }
.article-content { font-size: 0.95rem; line-height: 1.75; }
.article-content p { margin-bottom: 1rem; }
.article-content h2 { font-family: 'Fraunces', serif; font-size: 1.3rem; font-weight: 600; margin: 2rem 0 0.75rem; }
.article-content ul, .article-content ol { padding-left: 1.25rem; margin-bottom: 1rem; }
.article-content li { margin-bottom: 0.3rem; }
.article-content a { color: var(--green); text-decoration: underline; }
.event-meta-card { padding: 1.25rem; display: flex; flex-direction: column; gap: 1rem; }
.meta-row { display: flex; align-items: flex-start; gap: 0.75rem; }
.meta-icon { font-size: 1rem; margin-top: 0.1rem; flex-shrink: 0; }
.meta-label { font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--muted); font-weight: 500; }
.meta-value { font-size: 0.9rem; font-weight: 500; color: var(--text); margin-top: 0.1rem; }
</style>
